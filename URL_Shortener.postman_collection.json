{
  "info": {
    "_postman_id": "url-shortener-collection",
    "name": "URL Shortener API",
    "description": "Complete test collection for URL Shortener project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      },
      "response": []
    },
    {
      "name": "1. Create Generated Short URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has shortUrl\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('shortUrl');",
              "    pm.expect(jsonData.data.shortUrl).to.match(/^[a-zA-Z0-9]{6,8}$/);",
              "});",
              "pm.environment.set(\"short_code\", pm.response.json().data.shortUrl);",
              "pm.environment.set(\"url_id\", pm.response.json().data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"originalUrl\\\": \\\"https://github.com/torvalds/linux\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/shortner",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["shortner"]
        }
      },
      "response": []
    },
    {
      "name": "2. Create Custom Short URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Custom URL matches\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.shortUrl).to.equal('mytube');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"originalUrl\\\": \\\"https://www.youtube.com\\\",\\n  \\\"customUrl\\\": \\\"mytube\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/shortner",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["shortner"]
        }
      },
      "response": []
    },
    {
      "name": "3. Duplicate Custom URL (Should Fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 409\", function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "pm.test(\"Error message about duplicate\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('already exists');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"originalUrl\\\": \\\"https://www.twitter.com\\\",\\n  \\\"customUrl\\\": \\\"mytube\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/shortner",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["shortner"]
        }
      },
      "response": []
    },
    {
      "name": "4. Invalid URL (Should Fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test(\"Invalid URL error\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('Invalid');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"originalUrl\\\": \\\"not-a-valid-url\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/shortner",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["shortner"]
        }
      },
      "response": []
    },
    {
      "name": "5. Redirect to Original URL",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 302\", function () {",
              "    pm.response.to.have.status(302);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/{{short_code}}",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["{{short_code}}"]
        }
      },
      "response": []
    },
    {
      "name": "6. Get URL Analytics (Before Clicks)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Has shortUrl and totalClicks\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property('shortUrl');",
              "    pm.expect(jsonData.data).to.have.property('totalClicks');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/details/{{short_code}}?page=1&limit=10",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["details", "{{short_code}}"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "7. Redirect - Click 1",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/{{short_code}}",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["{{short_code}}"]
        }
      },
      "response": []
    },
    {
      "name": "8. Redirect - Click 2",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/{{short_code}}",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["{{short_code}}"]
        }
      },
      "response": []
    },
    {
      "name": "9. Redirect - Click 3",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/{{short_code}}",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["{{short_code}}"]
        }
      },
      "response": []
    },
    {
      "name": "10. Get Analytics After Clicks",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"totalClicks increased to 3\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.totalClicks).to.equal(3);",
              "});",
              "pm.test(\"Has visit records\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.data.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/details/{{short_code}}?page=1&limit=10",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["details", "{{short_code}}"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "11. Pagination - Page 1 Limit 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Limit is 1\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.limit).to.equal(1);",
              "});",
              "pm.test(\"Only 1 item returned\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.data.length).to.equal(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/details/{{short_code}}?page=1&limit=1",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["details", "{{short_code}}"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "1"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "12. Invalid Short Code (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test(\"Not found message\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include('not found');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}{{api_prefix}}/invalidcode",
          "host": ["{{base_url}}{{api_prefix}}"],
          "path": ["invalidcode"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "api_prefix",
      "value": "/api/v1"
    },
    {
      "key": "short_code",
      "value": ""
    },
    {
      "key": "url_id",
      "value": ""
    }
  ]
}
